{
  "rules": {
    ".read": false,
    ".write": false,

    "reviews": {
      ".read":  "auth != null && auth.token.email_verified === true && (auth.token.email === 'mikefiume13@gmail.com' || auth.token.email === 'anthonyfiume09@gmail.com')",
      ".write": "auth != null && auth.token.email_verified === true && (auth.token.email === 'mikefiume13@gmail.com' || auth.token.email === 'anthonyfiume09@gmail.com')",
      "$nameId": {
        ".validate": "newData.hasChildren(['status']) && newData.child('status').isString() && newData.child('status').val().length < 50",
        "status": { ".validate": true },
        "note":   { ".validate": "newData.isString() && newData.val().length < 5000" },
        "$other": { ".validate": false }
      }
    },

    "notes": {
      ".read":  "auth != null && auth.token.email_verified === true && (auth.token.email === 'mikefiume13@gmail.com' || auth.token.email === 'anthonyfiume09@gmail.com')",
      ".write": "auth != null && auth.token.email_verified === true && (auth.token.email === 'mikefiume13@gmail.com' || auth.token.email === 'anthonyfiume09@gmail.com')",
      ".validate": "newData.hasChildren() || !newData.exists()",
      "$field": {
        ".validate": "newData.isString() && newData.val().length < 20000"
      }
    },

    "customNames": {
      ".read":  "auth != null && auth.token.email_verified === true && (auth.token.email === 'mikefiume13@gmail.com' || auth.token.email === 'anthonyfiume09@gmail.com')",
      ".write": "auth != null && auth.token.email_verified === true && (auth.token.email === 'mikefiume13@gmail.com' || auth.token.email === 'anthonyfiume09@gmail.com')",
      "$index": {
        ".validate": "newData.hasChildren(['id','name'])",
        "id":   { ".validate": "newData.isString() && newData.val().length < 100" },
        "name": { ".validate": "newData.isString() && newData.val().length < 100" },
        "vibe": { ".validate": "newData.isString() && newData.val().length < 1000" },
        "$other": { ".validate": false }
      }
    },

    "pickOrder": {
      ".read":  "auth != null && auth.token.email_verified === true && (auth.token.email === 'mikefiume13@gmail.com' || auth.token.email === 'anthonyfiume09@gmail.com')",
      ".write": "auth != null && auth.token.email_verified === true && (auth.token.email === 'mikefiume13@gmail.com' || auth.token.email === 'anthonyfiume09@gmail.com')",
      "$index": {
        ".validate": "newData.isString() && newData.val().length < 100"
      }
    },

    "tournaments": {
      ".read":  "auth != null && auth.token.email_verified === true && (auth.token.email === 'mikefiume13@gmail.com' || auth.token.email === 'anthonyfiume09@gmail.com')",
      ".write": "auth != null && auth.token.email_verified === true && (auth.token.email === 'mikefiume13@gmail.com' || auth.token.email === 'anthonyfiume09@gmail.com')",
      "$tournamentId": {
        ".validate": "newData.hasChildren(['id','createdAt','contestants','matches'])",
        "id":          { ".validate": "newData.isString() && newData.val().length < 100" },
        "createdAt":   { ".validate": "newData.isNumber()" },
        "completedAt": { ".validate": "newData.isNumber()" },
        "contestants": {
          "$idx": {
            ".validate": "newData.hasChildren(['id','name'])",
            "id":   { ".validate": "newData.isString() && newData.val().length < 100" },
            "name": { ".validate": "newData.isString() && newData.val().length < 200" },
            "$other": { ".validate": false }
          }
        },
        "matches": {
          "$idx": {
            ".validate": "newData.hasChildren(['a','b'])",
            "a":       { ".validate": "newData.isString() && newData.val().length < 100" },
            "b":       { ".validate": "newData.isString() && newData.val().length < 100" },
            "winner":  { ".validate": "newData.isString() && newData.val().length < 100" },
            "skipped": { ".validate": "newData.isBoolean()" },
            "$other":  { ".validate": false }
          }
        },
        "$other": { ".validate": false }
      }
    }
  }
}
